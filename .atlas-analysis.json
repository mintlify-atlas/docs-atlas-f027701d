  "keyFeatures": [
    "Multi-branch cinema management across Mexico City locations",
    "Movie catalog with TMDB API integration for posters and metadata",
    "Screening schedule management with conflict detection",
    "Interactive seat selection and ticket purchasing",
    "Role-based access control (Admin, Employee, Customer)",
    "Google OAuth login via django-allauth",
    "Employee dashboard with full CRUD for movies, screenings, and genres",
    "Admin panel for user and branch management"
  ],
  "publicApiSurface": [
    "GET /api/buscar_tmdb/?query=<title>",
    "GET /api/detalles_tmdb/?tmdb_id=<id>",
    "GET /api/horarios_disponibles/?sala=<id>&fecha=<date>",
    "GET / (cartelera_view)",
    "GET /pelicula/<id>/ (detalle_pelicula_view)",
    "POST /funcion/<id>/comprar/ (comprar_boletos_view)",
    "POST /login/ (login_view)",
    "GET /logout/ (logout_view)"
  ]
